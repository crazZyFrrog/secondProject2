# Root / docs — скопируйте в apps/backend/.env и apps/frontend/.env

# Backend (apps/backend/.env)
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/landing_builder
JWT_SECRET=change-me-in-production-min-32-chars
# Несколько origin: через запятую или точку с запятой (; удобнее в Windows-скриптах без кавычек)
CORS_ORIGINS=http://localhost:5173;https://your-app.vercel.app
# Amvera задаёт PORT автоматически

# Frontend (apps/frontend/.env) — на Vercel обязателен URL Amvera; локально можно не задавать (прокси /api).
# VITE_API_URL=https://your-api.amvera.io
